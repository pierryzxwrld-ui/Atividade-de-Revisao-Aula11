#Questão 2: Faça um programa que solicite 10 números inteiros ao usuário e exiba A soma dos números e A média dos números
soma = 0
for i in range(10):
    num = int(input("Digite um numero inteiro:"))
    soma = soma + num
media = soma / 10
print("A soma dos numeros:",soma)
print("A media dos numeros:",media)
