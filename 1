#Questão 1: Faça um programa que leia a nota de um aluno (0 a 10) e informe sua situação Aprovado: nota maior ou igual a 7 Recuperação: nota entre 5 e 6,9 Reprovado: nota menor que 5
nota = float(input("Digite a nota do aluno:"))
while nota > 10 or nota < 0:
    nota = float(input("Por favor digite uma nota de 0 a 10:"))
if nota >= 7 and nota <= 10:
    print("ALUNO APROVADO!")
elif nota >= 5 and nota <= 6.9:
    print("ALUNO EM RECUPERAÇÃO")
else:
    print("ALUNO REPROVADO")
